# ─────────────────────────────────────────────────────────────────────────────
# apps/web/.env.example — шаблон для apps/web/.env.local
# Скопируй: cp apps/web/.env.example apps/web/.env.local
# ─────────────────────────────────────────────────────────────────────────────

# ─── API ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Публичный ключ (безопасно передавать в браузер — NEXT_PUBLIC_)
# Тестовый: Stripe Dashboard → Test mode → Developers → API keys → Publishable key (pk_test_...)
# Production: то же самое, но в Live mode (pk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ─── Google Analytics 4 ─────────────────────────────────────────────────────
# GA4 Measurement ID: Admin → Data Streams → Web → Measurement ID (G-XXXXXXXXXX)
# Leave empty to disable GA4 (safe for local development)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Google Search Console ──────────────────────────────────────────────────
# GSC → Settings → Ownership verification → HTML tag → copy content value
# Leave empty to skip verification meta tag
NEXT_PUBLIC_GSC_VERIFICATION_ID=

# ─── Klaviyo email marketing ────────────────────────────────────────────────
# Klaviyo → Account → Settings → API Keys → Public API Key (Company ID)
# Free up to 500 contacts, $20/mo up to 1000
NEXT_PUBLIC_KLAVIYO_COMPANY_ID=

# ─── Pinterest Tag & Rich Pins ──────────────────────────────────────────────
# Pinterest Business → Ads Manager → Conversions → Pinterest Tag → Tag ID
NEXT_PUBLIC_PINTEREST_TAG_ID=
# Pinterest → Claimed accounts → Websites → Claim → meta tag content
NEXT_PUBLIC_PINTEREST_VERIFICATION_ID=

# ─── Facebook Pixel ─────────────────────────────────────────────────────────
# Meta Business Manager → Events Manager → Pixel → Settings → Pixel ID
# Leave empty to disable (safe for local development)
NEXT_PUBLIC_FB_PIXEL_ID=

# ─── Sentry (error tracking) ─────────────────────────────────────────────────
# 1. Create free account: https://sentry.io
# 2. Create project → Next.js
# 3. Copy DSN from: Settings → Projects → <project> → Client Keys (DSN)
# Leave empty to disable Sentry (safe for local development)
NEXT_PUBLIC_SENTRY_DSN=
# Git tag or commit SHA — injected by CI/CD, used to link errors to releases
NEXT_PUBLIC_APP_VERSION=
# Required for source map upload during CI build (never exposed to browser)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
