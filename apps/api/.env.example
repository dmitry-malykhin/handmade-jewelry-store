# ─────────────────────────────────────────────────────────────────────────────
# apps/api/.env.example — шаблон для apps/api/.env
# Скопируй: cp apps/api/.env.example apps/api/.env
# Затем заполни значения (особенно JWT_SECRET в production!)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Сервер ──────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── База данных ─────────────────────────────────────────────────────────────
# Явные значения — переменные ${VAR} не работают в .env без dotenv-expand
DATABASE_URL="postgresql://jewelry_user:jewelry_pass@localhost:5432/jewelry_db?schema=public"

# ─── JWT (аутентификация) ─────────────────────────────────────────────────────
# В production: заменить на случайную строку 64+ символов
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_in_production_refresh
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS (заполнить при настройке S3) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Public base URL for S3 objects: https://{bucket}.s3.{region}.amazonaws.com
# Used to construct publicUrl returned by /api/upload/presigned-url
AWS_S3_PUBLIC_URL_PREFIX=https://your-bucket.s3.us-east-1.amazonaws.com

# ─── Stripe ───────────────────────────────────────────────────────────────────
#
# ── ТЕСТОВЫЕ КЛЮЧИ (для локальной разработки) ─────────────────────────────────
# 1. Зарегистрируйся / войди: https://dashboard.stripe.com
# 2. Убедись, что в Dashboard включён режим "Test mode" (переключатель сверху)
# 3. Перейди: Developers → API keys
# 4. Скопируй "Secret key" (начинается с sk_test_...)
#    НИКОГДА не используй sk_live_... в .env для локальной разработки!
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
#
# ── STRIPE_WEBHOOK_SECRET — два варианта ──────────────────────────────────────
#
# Вариант A: Локальная разработка через Stripe CLI (рекомендуется)
#   Шаг 1. Установи Stripe CLI: https://stripe.com/docs/stripe-cli#install
#           macOS:   brew install stripe/stripe-cli/stripe
#           Windows: scoop install stripe
#   Шаг 2. Авторизуйся: stripe login
#   Шаг 3. Запусти форвардинг: pnpm stripe:listen
#           → CLI выведет: "Your webhook signing secret is whsec_abc123..."
#           → Скопируй whsec_... в STRIPE_WEBHOOK_SECRET ниже
#   Примечание: whsec_ из CLI действителен только пока запущен stripe:listen
#
# Вариант B: Production (деплой на сервер)
#   1. Stripe Dashboard → Developers → Webhooks → Add endpoint
#   2. URL: https://your-domain.com/api/webhooks/stripe
#   3. Events: payment_intent.succeeded, payment_intent.payment_failed,
#              charge.refunded, charge.dispute.created
#   4. После создания: нажми "Reveal" → скопируй whsec_...
#   5. Добавь в переменные окружения сервера (НЕ в .env в репозитории!)
#
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# ─── Resend (email) ───────────────────────────────────────────────────────────
# 1. Зарегистрируйся: https://resend.com
# 2. Создай API key: Settings → API Keys → Create API Key
# 3. Вставь ключ ниже (начинается с re_...)
# В dev без ключа email просто не отправляется — API работает нормально
RESEND_API_KEY=re_your_resend_api_key_here

# ─── Email ────────────────────────────────────────────────────────────────────
# Email владельца магазина — получает уведомления о новых заказах и сообщения с контактной формы
STORE_OWNER_EMAIL=your@email.com

# ─── Sentry (мониторинг ошибок) ───────────────────────────────────────────────
# 1. Создай аккаунт: https://sentry.io (бесплатно)
# 2. Create Project → Node.js → выбери Nest.js
# 3. DSN: Settings → Projects → jewelry-api → Client Keys (DSN)
# Оставь пустым для локальной разработки — Sentry автоматически отключится
SENTRY_DSN=
# Git tag или commit SHA — проставляется CI/CD автоматически при деплое
# Используется для привязки ошибок к конкретному релизу в Sentry
APP_VERSION=
